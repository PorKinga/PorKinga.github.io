<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <title>Edit Pizza</title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
  </head>

  <body>
    <div class="container">
      <h1>Edit Pizza</h1>

      <form action="/pizzas/<%= pizza.id %>/edit" method="post">
        <div>
          <label for="name">Name</label>
          <input
            id="name"
            type="text"
            name="name"
            value="<%= pizza.name %>"
            required
          />
        </div>

        <div>
          <label for="description">Description</label>
          <input
            id="description"
            type="text"
            name="description"
            value="<%= pizza.description %>"
            required
          />
        </div>

        <div>
          <label for="price">Price</label>
          <input
            id="price"
            type="number"
            step="0.01"
            name="price"
            value="<%= pizza.price %>"
            required
          />
        </div>

        <button type="submit">Update</button>
      </form>

      <a href="/pizzas">back to list</a>

      <form action="/pizzas/<%= pizza.id %>/delete" method="post">
        <button type="submit">Delete</button>
      </form>
    </div>
  </body>
</html>